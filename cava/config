# ~/.config/cava/config

[general]
bars = 48

framerate = 60

sensitivity = 100
gravity = 1.8

[input]
method = pipewire
source = auto

[output]
method = raw
raw_target = /tmp/cava.fifo
bit_format = 8bit
channels = mono

[smoothing]
monstercat = 1
waves = 0
noise_reduction = 0.77

[eq]
1 = 1.2   
2 = 1.1
3 = 1.0
4 = 1.0
5 = 0.9
6 = 0.9
7 = 1.0
8 = 1.0
9 = 1.1
10 = 1.2
