# ~/.config/cava/config
# Config optimisée pour QuickShell sur Niri + Pipewire

[general]
# 20 barres correspond au barCount dans AudioVisualizer.qml
bars = 48

# Framerate cava — 60fps pour une animation fluide
framerate = 60

# Lissage : plus élevé = plus doux mais moins réactif (0-100)
sensitivity = 100
# Déclin des barres (vitesse de chute)
gravity = 1.8

[input]
method = pipewire
# Laisse vide pour capturer le sink par défaut (ce qui sort dans tes speakers)
source = auto

[output]
method = raw
# FIFO lu par QuickShell
raw_target = /tmp/cava.fifo
# 8bit : valeurs 0-255 par barre (1 octet par barre)
bit_format = 8bit
# Mono — on n'a pas besoin de stéréo pour le visu
channels = mono

[smoothing]
# Lissage temporel des barres
monstercat = 1
waves = 0
# Noise floor : ignore le bruit ambiant sous ce seuil
noise_reduction = 0.77

[eq]
# Boost léger des basses et aigus pour un rendu plus visuel
1 = 1.2   # sub-bass
2 = 1.1   # bass
3 = 1.0
4 = 1.0
5 = 0.9
6 = 0.9
7 = 1.0
8 = 1.0
9 = 1.1
10 = 1.2  # high
